# ── Copy this file to .env and adjust values ──────────────────────────────────
 
# Server
APP_TITLE="Deepfake Detection API"
APP_VERSION="1.0.0"
DEBUG=false
 
# CORS – comma-separated origins; use "*" for development only
CORS_ORIGINS="*"
 
# Model
# Directory containing xception/ and densenet/ subdirectories with weights.pth
MODEL_DIR=backend/weights
DEFAULT_MODEL=xception
 
# Inference
# Options: cpu | cuda | mps
DEVICE=cpu
INPUT_SIZE=299
 
# Upload
MAX_UPLOAD_MB=10.0
 
# Explainability
LIME_NUM_SAMPLES=64
LIME_NUM_FEATURES=10
 
# Logging
LOG_LEVEL=INFO
LOG_JSON=false
 
# Optional: write heatmap PNGs to disk for debugging
# ARTIFACT_DIR=/tmp/deepfake_artifacts